# ── Required for Netlify deployment ───────────────────
# Get token at: https://github.com/settings/tokens
# Scopes needed: gist (read + write)
GITHUB_TOKEN=your_github_personal_access_token_here

# Create a secret Gist at: https://gist.github.com
# Add a file named "redirects.json" with content: {}
# The Gist ID is the long string in the URL
GIST_ID=your_gist_id_here

# ── URL where this app is hosted ──────────────────────
# Change to your Netlify domain after deployment
BASE_URL=https://your-site.netlify.app

# ── Local dev only ─────────────────────────────────────
PORT=3000
